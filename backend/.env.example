# Port the backend HTTP + Socket.io server listens on
PORT=3001

# Comma-separated list of allowed CORS origins for the frontend.
# During local development the Vite dev server proxies requests, so this
# is mainly used when the frontend talks to the backend directly.
CLIENT_ORIGIN=http://localhost:3000

# Path to the SQLite database file (relative to the backend folder)
DATABASE_FILE=connectchat.db
